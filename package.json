{
  "name": "puerto-nuevo-montessori",
  "private": true,
  "version": "1.0.0",
  "description": "Plataforma Montessori Puerto Nuevo - Intranet educativa + Portal institucional",
  "type": "module",
  "scripts": {
    "predev": "node scripts/clean-dev-cache.cjs",
    "dev": "vite",
    "dev:emulated": "node scripts/dev-emulated.cjs",
    "dev:test-e2e": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "dev:test-emulated": "node scripts/dev-emulated.cjs --port 4173 --strict-port",
    "build": "vite build",
    "lint": "eslint . && npm run lint:guardrails",
    "lint:guardrails": "node scripts/lint-guardrails.cjs",
    "preview": "vite preview",
    "emulators": "firebase emulators:start --project demo-puerto-nuevo --only auth,firestore,functions,storage",
    "emulators:reset": "node scripts/reset-emulators.cjs",
    "seed:emulators": "node scripts/seed-emulators.cjs",
    "scheduled:snacks": "node scripts/run-scheduled.cjs snacks",
    "scheduled:appointments": "node scripts/run-scheduled.cjs appointments",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run --config vitest.emulator.config.js tests/rules",
    "setup:functions": "npm ci --prefix functions",
    "test:functions": "npm --prefix functions test",
    "test:e2e": "playwright test --config playwright.config.cjs",
    "test:e2e:smoke": "playwright test --config playwright.config.cjs --grep @smoke",
    "test:e2e:emulated": "playwright test --config playwright.emulator.config.cjs",
    "test:e2e:emulated:smoke": "playwright test --config playwright.emulator.config.cjs --grep @smoke",
    "test:all": "npm run test && npm run setup:functions && npm run test:functions && npm run test:e2e",
    "test:emulated": "firebase emulators:exec --project demo-puerto-nuevo --only auth,firestore,functions,storage \"node scripts/run-emulated-suite.cjs\"",
    "test:emulated:smoke": "firebase emulators:exec --project demo-puerto-nuevo --only auth,firestore,functions,storage \"node scripts/run-emulated-suite.cjs --smoke\"",
    "migrate:talleristaId": "node scripts/migrateTalleristaId.js",
    "migrate:talleristaId:apply": "node scripts/migrateTalleristaId.js --apply",
    "migrate:mojibake": "node scripts/fixMojibake.js",
    "migrate:mojibake:apply": "node scripts/fixMojibake.js --apply",
    "fix:utf8": "node scripts/fixSourceEncoding.js",
    "fix:utf8:apply": "node scripts/fixSourceEncoding.js --apply",
    "check:encoding": "node scripts/check-encoding.js",
    "fix:encoding": "node scripts/fix-encoding.js",
    "fix:encoding:apply": "node scripts/fix-encoding.js --apply"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "browser-image-compression": "^2.0.2",
    "d3-force-3d": "^3.0.6",
    "dompurify": "^3.4.1",
    "firebase": "^12.6.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.0.6",
    "heic2any": "^0.0.4",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "motion": "^12.38.0",
    "plyr": "^3.8.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-2d": "^1.29.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-security": "^4.0.0",
    "firebase-tools": "^14.8.1",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  }
}
